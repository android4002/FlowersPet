{
  "$schema": "https://opencode.ai/config.json",
  "model": "claude_subscription/claude-opus-4.8",
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow"
  },
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.next/**",
      "**/build/**",
      "**/dist/**",
      "**/.venv/**",
      "**/venv/**",
      "**/*.log",
      "**/package-lock.json",
      "**/poetry.lock",
      "**/.git/**"
    ]
  }
}
