# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local example: postgresql://user:password@localhost:5432/flowerspet
# Neon example:  postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/flowerspet

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat_id where order notifications will be sent
# Get it via @userinfobot or by sending a message to your bot and checking getUpdates
CHAT_ID=your_telegram_chat_id_here

# ─── Admin Panel ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
